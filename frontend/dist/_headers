# Cloudflare / Netlify / Amplify headers
# index.html: NUNCA cachear — é a âncora da detecção de versão
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Raiz também
/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Assets JS/CSS: cache longo (hash no nome garante invalidação automática)
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*.css
  Cache-Control: public, max-age=31536000, immutable
