{
  "name": "gres-backend",
  "version": "1.0.0",
  "description": "GRES Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext ts",
    "type-check": "tsc --noEmit",
    "deploy": "serverless deploy"
